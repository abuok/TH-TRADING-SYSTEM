# Common configurations
DEBUG=True
ENVIRONMENT=development

# Service-specific configs (if any)
INGESTION_PORT=8001
TECHNICAL_PORT=8002
RISK_PORT=8003
JOURNAL_PORT=8004

# Infrastructure
DATABASE_URL=postgresql://admin:admin@postgres:5432/trading_db
REDIS_URL=redis://redis:6379/0

# ── Provider selection ─────────────────────────────────────────────────────
# Controls which data provider is used on each production path.
# Defaults are 'mock' so CI never makes external network calls.
# In production, set to the real provider and ensure external credentials are set.

# Proxy data provider (DXY, US10Y, SPX, etc.)
# Options: mock | real
PROXY_PROVIDER=mock

# Economic calendar provider
# Options: mock | forexfactory
CALENDAR_PROVIDER=mock

# Live price-quote provider (for execution preflight spread/price checks)
# Options: mock | real
PRICE_PROVIDER=mock

# ── Dashboard service URLs ─────────────────────────────────────────────────
# Used by the dashboard health-check probes.
INGESTION_URL=http://localhost:8001
ORCHESTRATOR_URL=http://localhost:8000
TECHNICAL_URL=http://localhost:8002
