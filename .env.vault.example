# Production Secrets Template
# DO NOT COMMIT WITH ACTUAL VALUES
# Load from AWS Secrets Manager, HashiCorp Vault, or secure environment

# Database Credentials
POSTGRES_USER=${POSTGRES_USER:-postgres}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-change-in-vault}
POSTGRES_HOST=${POSTGRES_HOST:-postgres}
POSTGRES_PORT=${POSTGRES_PORT:-5432}
POSTGRES_DB=${POSTGRES_DB:-trading_journal}

# API Security
API_SECRET_KEY=${API_SECRET_KEY:-change-in-vault}
JWT_SECRET_KEY=${JWT_SECRET_KEY:-change-in-vault}
JWT_ALGORITHM=${JWT_ALGORITHM:-HS256}

# MT5 Bridge
MT5_API_KEY=${MT5_API_KEY:-change-in-vault}
MT5_MASTER_PASSWORD=${MT5_MASTER_PASSWORD:-change-in-vault}
MT5_SERVER=${MT5_SERVER:-change-in-vault}
MT5_LOGIN=${MT5_LOGIN:-change-in-vault}
MT5_PASSWORD=${MT5_PASSWORD:-change-in-vault}

# Alerting
TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN:-change-in-vault}
TELEGRAM_CHAT_ID=${TELEGRAM_CHAT_ID:-change-in-vault}

# AWS/Vault Configuration (for secret backends)
AWS_REGION=${AWS_REGION:-us-east-1}
AWS_SECRET_NAME=${AWS_SECRET_NAME:-trading-system/prod}
VAULT_ADDR=${VAULT_ADDR:-https://vault.example.com:8200}
VAULT_TOKEN=${VAULT_TOKEN:-change-in-vault}

# Deployment Environment
ENVIRONMENT=${ENVIRONMENT:-production}
LOG_LEVEL=${LOG_LEVEL:-INFO}
DEBUG=${DEBUG:-false}
