{
  "pythonVersion": "3.13",
  "pythonPlatform": "Windows",
  "pythonPath": "C:/Python313/python.exe",
  "venvPath": "C:/Python313",
  "extraPaths": [
    ".",
    "./shared",
    "./services",
    "./infra"
