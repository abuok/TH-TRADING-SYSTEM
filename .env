# Common configurations
DEBUG=True
ENVIRONMENT=development

# ── Infrastructure ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/trading_journal
REDIS_URL=redis://redis:6379/0

# Postgres service credentials (used by docker-compose postgres container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trading_journal

# ── Bridge Authentication ──────────────────────────────────────────────────────
# Must match the MT5 EA secret. Change in production.
BRIDGE_SECRET=change_me_in_production

# ── Telegram Alerting ─────────────────────────────────────────────────────────
# Leave blank to disable.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Provider selection ─────────────────────────────────────────────────────────
# Options: mock (CI-safe) | real (requires API keys below)
PROXY_PROVIDER=mock
CALENDAR_PROVIDER=mock
PRICE_PROVIDER=mock
SPEC_PROVIDER=mock

# Provider API keys (only needed for real providers)
FOREX_FACTORY_API_KEY=
TWELVE_DATA_API_KEY=

# ── Dashboard service health-check URLs ───────────────────────────────────────
# Port mapping (docker-compose): ingestion=8001, technical=8002, risk=8003,
#   journal=8004, dashboard=8005, orchestration=8006, bridge=8007 (disabled by default)
INGESTION_URL=http://localhost:8001
TECHNICAL_URL=http://localhost:8002
RISK_URL=http://localhost:8003
JOURNAL_URL=http://localhost:8004
DASHBOARD_URL=http://localhost:8005
ORCHESTRATOR_URL=http://localhost:8006
# BRIDGE_URL=http://localhost:8007   # uncomment when bridge is running
