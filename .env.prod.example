# PHX Trading System - Production Environment Template
# Rename this to .env.prod and fill in secrets

# Database
DATABASE_URL=postgresql://phx_prod_user:SECRET_PASSWORD@db:5432/phx_trading_prod
DB_USER=phx_prod_user
DB_PASSWORD=REPLACE_ME_SECURELY
DB_NAME=phx_trading_prod

# Redis
REDIS_URL=redis://redis:6379/0

# Security
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=REPLACE_ME_SECURELY
SECRET_KEY=GENERATE_A_LONG_SECURE_STRING

# Timezone
TZ=Africa/Nairobi

# Retention (days)
ARTIFACT_RETENTION_DAYS=30
LOG_RETENTION_DAYS=7

# Internal Service URIs
ORCHESTRATION_URL=http://orchestration:8003
JOURNAL_URL=http://journal:8004
